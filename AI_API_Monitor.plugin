#!name=AI API Monitor
#!desc=Loon 本地网页面板：测试 OpenAI 兼容 API、获取/手动添加模型、备注、导出、可选发送到 Telegram Bot
#!openUrl=http://aiapi.monitor/
#!author=YuUu / 薄荷
#!tag=工具
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/OpenAI.png
#!date=2026-05-17

[Rule]
DOMAIN,aiapi.monitor,DIRECT

[Script]
# 本地网页面板：浏览器打开 http://aiapi.monitor/
http-request ^https?:\/\/aiapi\.monitor\/?(?:.*)?$ script-path=https://raw.githubusercontent.com/yuu0402/loon/main/AI_API_Monitor_Panel.js, requires-body=false, timeout=120, tag=AI API Monitor 面板

[Argument]
# 无需定时任务。所有配置保存在 Loon 本地持久化存储里，不要上传 API Key / TG Bot Token 到公开仓库。
